# =============================================================================
# fraude-mlops — Variables de entorno
# =============================================================================
# Copiar este archivo como .env y completar con los valores locales:
#
#   macOS / Linux:  cp .env.example .env
#   Windows CMD:    copy .env.example .env
#   Windows PS:     Copy-Item .env.example .env
#
# NUNCA commitear el archivo .env (ya está en .gitignore)
# =============================================================================

# --- Kaggle API ---
# Token generado en https://www.kaggle.com → Settings → API → Create New Token
# El nuevo formato comienza con KGAT_ (no usar username/key en kaggle.json)
KAGGLE_API_TOKEN=KGAT_TU_TOKEN_AQUI
# Slug del dataset a descargar (por defecto: fraude en reclamaciones CMS)
# https://www.kaggle.com/datasets/nudratabbas/healthcare-fraud-detection-dataset
KAGGLE_DATASET=nudratabbas/healthcare-fraud-detection-dataset

# --- MLflow ---
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# Para servidor remoto:
# MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=healthcare-fraud-detection

# --- Prefect ---
PREFECT_API_URL=http://127.0.0.1:4200/api

# --- Rutas de datos y modelos ---
DATA_DIR=./data
MODELS_DIR=./models

# --- Pipeline ---
TRAIN_RATIO=0.8
OPTUNA_TRIALS=20
RANDOM_STATE=42

# --- Python ---
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
